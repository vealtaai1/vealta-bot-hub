// Prisma schema for PM Hub
//
// Notes:
// - We define `url` + `directUrl` here so Prisma can use a pooled URL at runtime
//   and a non-pooled/direct URL for migrations.
// - Set DATABASE_URL for app/runtime.
// - Set DIRECT_URL for migrations (recommended when using PgBouncer/Supabase/Neon pooling).
// - Per-project task numbering is implemented via ProjectTaskCounter.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AgentJobType {
  TASK_SUMMARY
  TASK_BREAKDOWN
  TASK_REWRITE
  PROJECT_DIGEST
  CUSTOM
}

enum AgentJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  STALE
}

enum AgentState {
  IDLE
  WORKING
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  displayName String?
  avatarUrl   String?

  disabledAt  DateTime?
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedProjects   Project[]           @relation("ProjectOwner")
  memberships     ProjectMembership[]
  createdInvites  ProjectInvite[]     @relation("InviteCreator")
  acceptedInvites ProjectInvite[]     @relation("InviteAcceptor")

  createdTasks        Task[]           @relation("TaskCreator")
  assignedTasks       Task[]           @relation("TaskAssignee")
  comments            TaskComment[]
  attachmentsUploaded TaskAttachment[]

  agentJobsRequested AgentJob[] @relation("AgentJobRequestedBy")
}

model Project {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Optional human-friendly identifier.
  slug String? @unique

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships ProjectMembership[]
  invites     ProjectInvite[]

  columns ProjectColumn[]
  tasks   Task[]

  taskCounter ProjectTaskCounter?
  agentJobs   AgentJob[]

  @@index([ownerId])
}

model ProjectMembership {
  id        String @id @default(cuid())
  projectId String
  userId    String

  role ProjectRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectInvite {
  id        String @id @default(cuid())
  projectId String

  // Who is invited (email-based so they can sign up later).
  email String

  // Store only a hash of the invite token (never store raw token).
  tokenHash String @unique

  status InviteStatus @default(PENDING)

  createdById String
  createdBy   User   @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Restrict)

  acceptedById String?
  acceptedBy   User?     @relation("InviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedAt   DateTime?

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
  @@index([status])
}

model ProjectColumn {
  id        String @id @default(cuid())
  projectId String

  name String

  // Display ordering within the project board.
  position Int

  // Soft delete/archival if you want to keep history.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, position])
  @@index([projectId])
}

model ProjectTaskCounter {
  // 1:1 with Project
  projectId String @id
  next      Int    @default(1)

  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id        String @id @default(cuid())
  projectId String

  // Per-project human-friendly task number (e.g., PROJ-123).
  number Int

  title       String
  description String?

  columnId String?
  column   ProjectColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Board ordering inside a column.
  position Int?

  dueAt       DateTime?
  completedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  comments    TaskComment[]
  attachments TaskAttachment[]
  agentJobs   AgentJob[]

  @@unique([projectId, number])
  @@index([projectId, columnId])
  @@index([assigneeId])
}

model TaskComment {
  id       String @id @default(cuid())
  taskId   String
  authorId String

  body String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([authorId])
}

model TaskAttachment {
  id           String @id @default(cuid())
  taskId       String
  uploadedById String

  // Metadata
  filename  String
  mimeType  String?
  sizeBytes Int?

  // Storage pointers
  url        String?
  storageKey String?

  createdAt DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([uploadedById])
}

model AgentJob {
  id String @id @default(cuid())

  // Scope
  projectId String?
  taskId    String?

  type   AgentJobType   @default(CUSTOM)
  status AgentJobStatus @default(QUEUED)

  // Requester
  requestedById String?
  requestedBy   User?   @relation("AgentJobRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  // Progress / observability
  progress Int? // 0..100 (optional)
  message  String?
  error    String?

  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?

  // Free-form payloads (inputs/outputs/logs)
  input  Json?
  output Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
  @@index([taskId])
  @@index([requestedById])
}

model AgentStatus {
  id String @id @default(cuid())

  agentId String @unique
  name    String?
  state   AgentState @default(IDLE)

  currentTask String?
  botCount    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}
